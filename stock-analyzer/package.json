{
  "name": "stock-analyzer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose up -d && pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "db:start": "docker-compose up -d postgres",
    "db:stop": "docker-compose stop postgres"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.0.0"
}
