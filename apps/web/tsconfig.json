{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@cryptotrading/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@cryptotrading/shared-types/*": ["../../packages/shared-types/src/*"]
    },
    "strict": false
  }
}
