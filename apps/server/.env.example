DB_HOST=localhost
DB_PORT=5432
DB_USER=cryptouser
DB_PASS=cryptopass
DB_NAME=cryptodb

SERVER_PORT=3000

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com

TUSHARE_TOKEN=

# Tushare 并发与限速
TUSHARE_CONCURRENCY=5
TUSHARE_MIN_INTERVAL_MS=200
TUSHARE_MAX_INTERVAL_MS=5000

# LLM provider for daily-review
# LLM_PROVIDER 可选值：deepseek | mimo
#   - deepseek: LLM_BASE_URL=https://api.deepseek.com,        LLM_MODEL=deepseek-v4-pro
#   - mimo:     LLM_BASE_URL=https://api.xiaomimimo.com/v1,   LLM_MODEL=mimo-v2.5-pro
LLM_PROVIDER=mimo
LLM_API_KEY=
LLM_BASE_URL=https://api.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro

# Daily-review tool-calling pipeline
# Tavily 是 LLM 检索专用搜索 API（主源）。申请：https://tavily.com 注册后控制台拿 key
# Serper 是 Google Search API（兜底）。申请：https://serper.dev
TAVILY_API_KEY=
SERPER_API_KEY=

# Investigator (Stage1) 预算与超时
DAILY_REVIEW_TOOL_BUDGET=8
DAILY_REVIEW_TOOL_TIMEOUT_MS=15000
DAILY_REVIEW_INVESTIGATOR_TIMEOUT_MS=300000

# 隔夜美股拉取开关（关闭时 snapshot.overnight=null）
DAILY_REVIEW_OVERNIGHT_ENABLED=true

# ---- M2 Part H 新增：量化模块 SSE 短期 token 密钥 ----
# 用于 POST /quant/jobs/:id/sse-token 颁发的 5 分钟 token 的 HMAC-SHA256 签名
# 三个键 (QUANT_SSE_TOKEN_SECRET / QUANT_SSE_SECRET / JWT_SECRET) 任一可用，按此优先级 fallback
QUANT_SSE_TOKEN_SECRET=please-generate-a-32+char-random-string
